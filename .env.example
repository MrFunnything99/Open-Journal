# Required: OpenRouter for /chat, journal validation, voice memo polish, date inference, and library extraction helpers.
# Perplexity for embeddings + Search API.
# Get keys: https://openrouter.ai/keys | https://docs.perplexity.ai/docs/getting-started/quickstart
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Default chat model for /chat (LangGraph interviewer). Override on OpenRouter if needed.
# OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
# Optional fallback when the primary model errors or the tool loop can't complete.
# OPENROUTER_CHAT_FALLBACK_MODEL=openai/gpt-5.4
# Conversation mode uses a separate model with reasoning enabled (default: x-ai/grok-4.1-fast).
# Journal mode uses OPENROUTER_CHAT_MODEL. Assisted Journal (mode=autobiography) defaults to openai/gpt-5-mini.
# OPENROUTER_ASSISTED_JOURNAL_MODEL=openai/gpt-5-mini
# OPENROUTER_CONVERSATION_MODEL=x-ai/grok-4.1-fast
# Speech-to-text for /api/transcribe and /api/voice-memo (multimodal audio via OpenRouter). Override if needed.
# https://openrouter.ai/docs/guides/overview/multimodal/audio
# OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-audio-mini

# Text-to-speech for chat read-aloud and Assisted Journal voice mode (/api/voice): Mistral Voxtral (required for TTS).
# https://docs.mistral.ai/capabilities/audio/text_to_speech
MISTRAL_API_KEY=your_mistral_api_key_here
# Default catalog voice is en_paul_neutral (Paul · neutral from GET /v1/audio/voices). Override with any slug or UUID:
# MISTRAL_TTS_VOICE_ID=en_paul_neutral
# Optional playback speed hint for the browser player (OpenAPI has no server-side speed). Default 1.05.
# MISTRAL_TTS_PLAYBACK_RATE=1.05
# Audio format for read-aloud (opus = smaller payload; alternatives: mp3 wav flac):
# MISTRAL_TTS_RESPONSE_FORMAT=opus
# Optional model override (default voxtral-mini-tts-2603):
# MISTRAL_TTS_MODEL=voxtral-mini-tts-2603

# Required for sqlite-vec memory (gist, episodic, library embeddings): https://docs.perplexity.ai/docs/getting-started/quickstart

# Optional: default is contextual 4B model (POST /v1/contextualizedembeddings). For standard embeddings use e.g. pplx-embed-v1-4b
# PERPLEXITY_EMBEDDING_MODEL=pplx-embed-context-v1-4b
# Optional: must match embedding length stored in SQLite (default 2560 for full 4B output)
# EMBEDDING_DIM=2560

# Optional LightRAG (off by default). Primary memory is sqlite-vec only unless set to true.
# LIGHTRAG_ENABLED=false

# Optional fallback when OPENROUTER_API_KEY is unset: OpenAI audio API for STT (dev Node transcribe handler).
# OPENAI_API_KEY=sk-...
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional: Model for Recommendations tab (OpenRouter id). Override if needed.
# RECOMMENDATIONS_MODEL=openai/gpt-4.1-mini

# Optional: Podcast recommendations use Listen Notes API for real episode links (https://www.listennotes.com/api/docs/)
# LISTENNOTES_API_KEY=your_listennotes_api_key

# Optional: ISO 3166-1 alpha-2 for Perplexity news search localization (default US). https://docs.perplexity.ai/api-reference/search-post
# PERPLEXITY_NEWS_COUNTRY=US

# Optional: Research paper recommendations use Semantic Scholar + PubMed. Without this key, we throttle S2 requests to avoid 429. With a key (https://www.semanticscholar.org/product/api) you get higher rate limits.
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# Required for two-token auth (/api/register, /api/login, /api/refresh). Use a long random string.
# JWT_SECRET=your_long_random_secret_here
#
# On Fly.io: fly secrets set JWT_SECRET="your_long_random_secret_here"
#
# For production refresh cookie (secure=True): set ENVIRONMENT=production

# Optional: If backend port is not 8000:
# API_PORT=8000
# VITE_API_URL=http://localhost:8000

# Library / memory extraction LLM (OpenRouter chat completions). Legacy alias: OPENROUTER_GEMINI_MODEL.
# OPENROUTER_EXTRACTION_MODEL=openai/gpt-4.1-mini
# OPENROUTER_EXTRACTION_TEMPERATURE=0.7
# OPENROUTER_EXTRACTION_TIMEOUT_SEC=75
# OPENROUTER_EXTRACTION_MAX_TOKENS=8192
#
# Voice memo: optional transcript polish after STT (OpenRouter).
# OPENROUTER_VOICE_MEMO_POLISH_MODEL=openai/gpt-4.1-mini
#
# Journal-mode auto-cleanup (light filler/punctuation/casing cleanup after STT).
# Only runs when journal_mode=true in /api/voice-memo requests.
# OPENROUTER_JOURNAL_CLEANUP_MODEL=openai/gpt-5.4-mini
#
# Journal entry date inference (/infer-entry-date) when text has no explicit date.
# OPENROUTER_INFER_ENTRY_DATE_MODEL=openai/gpt-4.1-mini
#
# Journal folder/ZIP import: filing date from file path/name only via OpenRouter (default MiniMax M2.7). No file contents sent.
# OPENROUTER_JOURNAL_FILENAME_DATE_MODEL=minimax/minimax-m2.7
#
# Books, articles, and research: xAI Grok + web via OpenRouter (`:online` enables provider search).
# OPENROUTER_LIBRARY_WEB_MODEL=x-ai/grok-4.1-fast:online
# OPENROUTER_LIBRARY_WEB_TIMEOUT_SEC=120
# OPENROUTER_LIBRARY_FAST_TIMEOUT_SEC=90
# OPENROUTER_LIBRARY_FAST_MODEL=x-ai/grok-4.1-fast
#
# Book extraction (extract_books_read): batched LLM normalizes title/author (no Open Library HTTP right now).
# OPENROUTER_BOOK_VALIDATION_MODEL=openai/gpt-4.1-mini
# Open Library (disabled in code — restore urllib bodies in library.py when re-enabling):
# OPENLIBRARY_HTTP_TIMEOUT_SEC=3.5
# OPENLIBRARY_USER_AGENT=SelfMeridian/1.0 (https://github.com/...)
#
# Recommendations (/api/recommendations): five agents run in parallel; Perplexity sub-searches also run in parallel per agent.
# RECOMMENDATIONS_AGENT_TIMEOUT_SEC=68
# RECOMMENDATIONS_HTTP_TIMEOUT_SEC=78
# RECOMMENDATIONS_PPLX_MERGE_WAIT_CAP_SEC=52
# Same optional headers as other OpenRouter calls:
# OPENROUTER_REFERER=https://selfmeridian.local
# OPENROUTER_TITLE=SelfMeridian
#
# Learning Tab: Grok 4.1 (reasoning) reads first + latest journal entries → 3-4 themes, each with 2-3 sentences;
# Claude (below) uses that per-theme brief for web article search, pick, and reflection chat.
# OPENROUTER_LEARNING_GROK_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_LEARNING_MODEL=anthropic/claude-opus-4.6
# Full Grok raw JSON + parsed brief (append). Default: backend/logs/learning_synthesis.log
# Set to disable: LEARNING_SYNTHESIS_LOG=off
# LEARNING_SYNTHESIS_LOG=C:/path/to/learning_synthesis.log
