# =============================================================================
# SelfMeridian — copy to .env in the project root (backend loads it from here)
# =============================================================================

# --- Required: all inference, embeddings, and STT route through Tinfoil ---
# https://tinfoil.sh/
TINFOIL_API_KEY=

# --- Optional: Tinfoil model overrides ---
# TINFOIL_CHAT_MODEL=kimi-k2-6
# TINFOIL_CHAT_FALLBACK_MODEL=deepseek-v4-pro
# TINFOIL_CONVERSATION_MODEL=kimi-k2-6
# TINFOIL_ASSISTED_JOURNAL_MODEL=kimi-k2-6
# TINFOIL_VOICE_MEMO_POLISH_MODEL=kimi-k2-6
# TINFOIL_JOURNAL_VALIDATE_MODEL=kimi-k2-6
# TINFOIL_INFER_ENTRY_DATE_MODEL=kimi-k2-6
# TINFOIL_JOURNAL_FILENAME_DATE_MODEL=kimi-k2-6
# TINFOIL_EXTRACTION_MODEL=kimi-k2-6
# TINFOIL_EXTRACTION_TEMPERATURE=0.7
# TINFOIL_EXTRACTION_TIMEOUT_SEC=120
# TINFOIL_EXTRACTION_MAX_TOKENS=8192
# TINFOIL_BOOK_VALIDATION_MODEL=kimi-k2-6
# TINFOIL_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# TINFOIL_EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768

# --- Reserved for future podcast search ---
# LISTENNOTES_API_KEY=

# --- OpenLibrary book lookup ---
# OpenLibrary does not require an API key; book lookup remains enabled by default.

# --- Optional: authentication ---
# JWT_SECRET=
# ENVIRONMENT=production

# --- Optional: memory / infra ---
# VECTOR_DB_PATH=/absolute/path/to/open_journal.db
# CORS_ORIGINS=https://your-domain.com

# --- Optional: local dev proxy ---
# VITE_API_URL=http://localhost:8000
# API_PORT=3001
