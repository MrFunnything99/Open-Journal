# Required for Interviewer and Reformat API routes
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required for Voice (TTS) and Speech-to-Text API routes
# Get your key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Model for Recommendations tab (article URLs must work). Default: Gemini 3.1 Pro.
# RECOMMENDATIONS_MODEL=google/gemini-3.1-pro-preview
# If 3.1 is unavailable, try: google/gemini-2.5-pro

# Optional: Podcast recommendations use Listen Notes API for real episode links (https://www.listennotes.com/api/docs/)
# LISTENNOTES_API_KEY=your_listennotes_api_key

# Optional: News & article recommendations use Tavily Search (https://docs.tavily.com/welcome). When set, article suggestions use real web search results (topic=news).
# TAVILY_API_KEY=your_tavily_api_key

# Optional: Research paper recommendations use Semantic Scholar + PubMed. Without this key, we throttle S2 requests to avoid 429. With a key (https://www.semanticscholar.org/product/api) you get higher rate limits.
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# Required for two-token auth (/api/register, /api/login, /api/refresh). Use a long random string.
# JWT_SECRET=your_long_random_secret_here
#
# On Fly.io: fly secrets set JWT_SECRET="your_long_random_secret_here"
#
# For production refresh cookie (secure=True): set ENVIRONMENT=production

# Optional: If backend port is not 8000:
# API_PORT=8000
# VITE_API_URL=http://localhost:8000

XAI_API_KEY=your_xai_api_key_here

