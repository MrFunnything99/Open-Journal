# =============================================================================
# SelfMeridian — copy to .env in the project root (backend loads it from here)
# =============================================================================

# --- Required for journaling + chat + STT (assisted journal does not use vector retrieval) ---
# https://openrouter.ai/keys — add credits under Billing if needed. Models: https://openrouter.ai/models
OPENROUTER_API_KEY=

# --- Optional: embeddings / ingest when you use those pipelines (not needed for default assisted journal) ---
# https://docs.perplexity.ai/docs/getting-started/quickstart
PERPLEXITY_API_KEY=

# --- Optional: read-aloud TTS ---
# https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Optional: authentication ---
# JWT_SECRET=
# ENVIRONMENT=production

# --- Optional: OpenRouter HTTP headers (analytics/rankings on OpenRouter side) ---
# OPENROUTER_REFERER=https://selfmeridian.local
# OPENROUTER_TITLE=SelfMeridian

# --- Optional: override default OpenRouter model IDs (defaults live in backend code) ---
# OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
# OPENROUTER_CHAT_FALLBACK_MODEL=openai/gpt-5.4
# OPENROUTER_CONVERSATION_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_ASSISTED_JOURNAL_MODEL=openai/gpt-5-mini
# OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-audio-mini
# OPENROUTER_TRANSCRIPTION_FALLBACK_MODEL=xiaomi/mimo-v2-omni
# OPENROUTER_VOICE_MEMO_POLISH_MODEL=openai/gpt-5.4
# OPENROUTER_JOURNAL_CLEANUP_MODEL=openai/gpt-5.4-mini
# OPENROUTER_INFER_ENTRY_DATE_MODEL=openai/gpt-4.1-mini
# OPENROUTER_JOURNAL_FILENAME_DATE_MODEL=minimax/minimax-m2.7
# OPENROUTER_EXTRACTION_MODEL=google/gemini-3-pro-preview
# OPENROUTER_GEMINI_MODEL=google/gemini-3-pro-preview
# OPENROUTER_EXTRACTION_TEMPERATURE=0.7
# OPENROUTER_EXTRACTION_TIMEOUT_SEC=75
# OPENROUTER_EXTRACTION_MAX_TOKENS=8192
# OPENROUTER_LIBRARY_WEB_MODEL=x-ai/grok-4.1-fast:online
# OPENROUTER_LIBRARY_WEB_TIMEOUT_SEC=120
# OPENROUTER_LIBRARY_FAST_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_LIBRARY_FAST_TIMEOUT_SEC=90
# OPENROUTER_BOOK_VALIDATION_MODEL=openai/gpt-4.1-mini
# OPENROUTER_LEARNING_GROK_MODEL=x-ai/grok-4.1-fast
# OPENROUTER_LEARNING_MODEL=anthropic/claude-opus-4.6

# --- Optional: Perplexity embeddings tuning ---
# PERPLEXITY_EMBEDDING_MODEL=pplx-embed-context-v1-4b
# EMBEDDING_DIM=2560
# PERPLEXITY_NEWS_COUNTRY=US

# --- Optional: Mistral TTS tuning ---
# MISTRAL_TTS_VOICE_ID=en_paul_neutral
# MISTRAL_TTS_PLAYBACK_RATE=1.05
# MISTRAL_TTS_RESPONSE_FORMAT=opus
# MISTRAL_TTS_MODEL=voxtral-mini-tts-2603

# --- Optional: dev STT fallback (Node /api/transcribe only; backend prefers OpenRouter) ---
# OPENAI_API_KEY=
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# --- Optional: memory / infra ---
# LIGHTRAG_ENABLED=false
# VECTOR_DB_PATH=/absolute/path/to/open_journal.db
# CORS_ORIGINS=https://your-domain.com

# --- Optional: recommendations enrichment ---
# TAVILY_API_KEY=
# LISTENNOTES_API_KEY=
# SEMANTIC_SCHOLAR_API_KEY=

# --- Optional: local dev proxy ---
# VITE_API_URL=http://localhost:8000
# API_PORT=3001

# --- Optional: learning tab logging ---
# LEARNING_SYNTHESIS_LOG=off
